{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "ThisIsMyQuant 默认权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:window:allow-internal-toggle-maximize",
    "shell:allow-open",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
