# ============================================================
# ThisIsMyQuant — 环境变量模板
# ============================================================
# 复制为 .env 或运行 scripts/sync-env.sh
# ============================================================

# -------------------- 数据库 --------------------
DATABASE_URL=sqlite:///data/quant.db

# ==================== LLM API Keys ====================
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2.0-pro
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=deepseek-chat
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-plus
DEFAULT_LLM_PROVIDER=doubao

# -------------------- 数据源（AKShare K 线 + 金十资讯） --------------------
AKSHARE_ENABLED=true
AKSHARE_REALTIME_ENABLED=true
REALTIME_POLL_INTERVAL=5
WATCHLIST=rb2510,au2512,IF2512
JINSHI_ENABLED=true
JINSHI_API_BASE=https://mp-api.jin10.com
JINSHI_CACHE_TTL=300
JINSHI_POLL_INTERVAL=300

# 金十财经日历（rili 开放 API；502 时可配置 MCP Token 备用）
JINSHI_RILI_API_BASE=https://e0430d16720e4211b5e072c26205c890.z3c.jin10.com
JINSHI_RILI_APP_ID=sKKYe29sFuJaeOCJ
# 可选：金十官方 MCP Token（https://mcp.jin10.com/app）
JIN10_MCP_TOKEN=
JIN10_MCP_SERVER_URL=https://mcp.jin10.com/mcp
JIN10_MCP_PROTOCOL_VERSION=2025-11-25

# -------------------- 分析任务调度 --------------------
DAILY_ANALYSIS_CRON="0 17"
REALTIME_ANALYSIS_INTERVAL=300

# -------------------- 流动性分层（可选） --------------------
LIQUIDITY_MIN_VOLUME_20D=5000
LIQUIDITY_MIN_TURNOVER_20D=500000000

# -------------------- 资讯 LLM 分类（可选） --------------------
NEWS_CLASSIFY_LLM_ENABLED=true
NEWS_CLASSIFY_LLM=
NEWS_CLASSIFY_BATCH=10

# -------------------- 日志 --------------------
LOG_LEVEL=INFO
LOG_DIR=logs
